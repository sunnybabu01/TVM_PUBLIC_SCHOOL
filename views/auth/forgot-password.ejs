<%- include('../partials/header') %>

<div class="login-body">
  <div class="ambient-bubble bubble-1" style="background: var(--accent-sunset);"></div>
  <div class="ambient-bubble bubble-2" style="background: var(--accent-purple);"></div>
  
  <div class="container d-flex justify-content-center align-items-center">
    <div class="glass-card login-card px-4 py-5 shadow-lg border border-secondary" style="background: rgba(15, 23, 42, 0.7);">
      
      <!-- Icon and title -->
      <div class="login-header mb-4">
        <i class="fa-solid fa-key text-info fs-1 mb-2"></i>
        <h2 class="login-title">Forgot Password?</h2>
        <p class="text-secondary mb-0 mt-1" style="font-size: 0.9rem;">Submit your details to receive a recovery OTP code on your email.</p>
      </div>

      <!-- Alert alerts -->
      <%- include('../partials/messages') %>

      <!-- Forgot Password Form -->
      <form action="/forgot-password" method="POST">
        
        <!-- User ID -->
        <div class="mb-3">
          <label for="userId" class="glass-label"><i class="fa-regular fa-id-badge me-2 text-info"></i>User ID or Registered Email</label>
          <input type="text" name="userId" id="userId" class="form-control glass-input" placeholder="e.g. STD20260001, TCH20260001" required>
        </div>

        <!-- Role Selector -->
        <div class="mb-4">
          <label for="role" class="glass-label"><i class="fa-solid fa-users-gear me-2 text-info"></i>Access Role</label>
          <select name="role" id="role" class="form-select glass-input text-white" style="background-color: var(--bg-slate);" required>
            <option value="" disabled selected>Select Portal Access...</option>
            <option value="student">Student Portal</option>
            <option value="teacher">Teacher / Faculty</option>
            <option value="admin">Director / Admin</option>
          </select>
        </div>

        <!-- Submit -->
        <button type="submit" class="btn btn-tvm-primary w-100 py-3 text-uppercase font-weight-bold">
          <i class="fa-solid fa-paper-plane me-2"></i>Send Recovery Code
        </button>

      </form>

      <!-- Action items -->
      <div class="text-center mt-4">
        <a href="/login" class="text-secondary text-decoration-none" style="font-size: 0.85rem;">
          <i class="fa-solid fa-arrow-left me-2"></i>Back to Sign In
        </a>
      </div>

    </div>
  </div>
</div>

<%- include('../partials/footer') %>
