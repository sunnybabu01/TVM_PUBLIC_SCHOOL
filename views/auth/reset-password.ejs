<%- include('../partials/header') %>

<div class="login-body">
  <div class="ambient-bubble bubble-1" style="background: var(--accent-emerald);"></div>
  <div class="ambient-bubble bubble-2" style="background: var(--accent-cyan);"></div>
  
  <div class="container d-flex justify-content-center align-items-center">
    <div class="glass-card login-card px-4 py-5 shadow-lg border border-secondary" style="background: rgba(15, 23, 42, 0.7);">
      
      <!-- Icon and title -->
      <div class="login-header mb-4">
        <i class="fa-solid fa-arrows-rotate text-success fs-1 mb-2"></i>
        <h2 class="login-title">Reset Password</h2>
        <p class="text-secondary mb-0 mt-1" style="font-size: 0.9rem;">Specify recovery OTP and set your new account password below.</p>
      </div>

      <!-- Alert alerts -->
      <%- include('../partials/messages') %>

      <% if (typeof debugOtp !== 'undefined' && debugOtp) { %>
        <div class="alert alert-info border border-info border-opacity-25 text-center py-3 mb-4" style="background: rgba(0, 242, 254, 0.08); border-radius: 12px;">
          <i class="fa-solid fa-circle-info text-info me-2 fs-5"></i>
          <span class="text-white">Development Help OTP:</span> 
          <strong class="text-info fs-5 ms-1" style="letter-spacing: 2px;"><%= debugOtp %></strong>
          <p class="text-secondary small mb-0 mt-1">*(Since SMTP is not configured in .env, the recovery OTP is displayed here for offline testing)*</p>
        </div>
      <% } %>

      <!-- Reset Password Form -->
      <form action="/reset-password" method="POST">
        
        <!-- Hidden Inputs for context -->
        <input type="hidden" name="userId" value="<%= userId %>">
        <input type="hidden" name="role" value="<%= role %>">
        
        <!-- Display Context -->
        <div class="mb-3 text-center bg-dark rounded p-2 border border-secondary">
          <span class="text-secondary style='font-size: 0.8rem;'">Account ID:</span>
          <strong class="text-white ms-1" style="font-size: 0.85rem;"><%= userId %></strong>
          <span class="badge text-uppercase ms-2 bg-secondary" style="font-size: 0.7rem;"><%= role %></span>
        </div>

        <!-- OTP Input -->
        <div class="mb-3">
          <label for="otp" class="glass-label"><i class="fa-solid fa-shield-halved me-2 text-info"></i>6-Digit Recovery OTP</label>
          <input type="text" name="otp" id="otp" class="form-control glass-input text-center fs-4 font-weight-bold letter-spacing-4" placeholder="000000" maxlength="6" autocomplete="off" required>
        </div>

        <!-- New Password -->
        <div class="mb-3">
          <label for="newPassword" class="glass-label"><i class="fa-solid fa-lock me-2 text-success"></i>New Password</label>
          <input type="password" name="newPassword" id="newPassword" class="form-control glass-input" placeholder="••••••••" required>
        </div>

        <!-- Confirm Password -->
        <div class="mb-4">
          <label for="confirmPassword" class="glass-label"><i class="fa-solid fa-circle-check me-2 text-success"></i>Confirm New Password</label>
          <input type="password" name="confirmPassword" id="confirmPassword" class="form-control glass-input" placeholder="••••••••" required>
        </div>

        <!-- Submit -->
        <button type="submit" class="btn btn-tvm-primary w-100 py-3 text-uppercase font-weight-bold">
          <i class="fa-solid fa-lock-open me-2"></i>Authorize Password Update
        </button>

      </form>

      <!-- Action items -->
      <div class="text-center mt-4">
        <a href="/login" class="text-secondary text-decoration-none" style="font-size: 0.85rem;">
          <i class="fa-solid fa-arrow-left me-2"></i>Back to Sign In
        </a>
      </div>

    </div>
  </div>
</div>

<%- include('../partials/footer') %>
