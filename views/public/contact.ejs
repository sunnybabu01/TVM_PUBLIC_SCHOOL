  </div>
</nav>

<!-- Page Header -->
<section class="py-5" style="background: rgba(255, 255, 255, 0.01); border-bottom: 1px solid var(--border-glass);">
  <div class="container text-center">
    <h1 class="text-white font-weight-bold mb-3">Contact Admissions Desk</h1>
    <p class="text-secondary mb-0">Have queries about admission criteria, fees, or curricula? Drop us a line below.</p>
  </div>
</section>

<!-- Content -->
<section class="py-5">
  <div class="container">
    <div class="row g-5">
      
      <!-- Contact Info -->
      <div class="col-lg-5">
        <div class="glass-card shadow-lg border border-secondary p-4 h-100 card-cyan">
          <h4 class="text-white font-weight-bold mb-4">TVM Public School, Patna</h4>
          
          <div class="d-flex align-items-start gap-3 mb-4">
            <span class="p-3 bg-info bg-opacity-10 rounded-circle text-info border border-info border-opacity-25">
              <i class="fa-solid fa-location-dot"></i>
            </span>
            <div>
              <h6 class="text-white font-weight-bold mb-1">Campus Location</h6>
              <p class="text-secondary mb-0" style="font-size: 0.9rem;">Bailey Road, Near Danapur Flyover, Patna, Bihar - 801503</p>
            </div>
          </div>

          <div class="d-flex align-items-start gap-3 mb-4">
            <span class="p-3 bg-info bg-opacity-10 rounded-circle text-info border border-info border-opacity-25">
              <i class="fa-solid fa-envelope"></i>
            </span>
            <div>
              <h6 class="text-white font-weight-bold mb-1">Email Queries</h6>
              <p class="text-secondary mb-0" style="font-size: 0.9rem;">admissions@tvmpublicschool.com<br>info@tvmpublicschool.com</p>
            </div>
          </div>

          <div class="d-flex align-items-start gap-3">
            <span class="p-3 bg-info bg-opacity-10 rounded-circle text-info border border-info border-opacity-25">
              <i class="fa-solid fa-phone"></i>
            </span>
            <div>
              <h6 class="text-white font-weight-bold mb-1">Helpline Desk</h6>
              <p class="text-secondary mb-0" style="font-size: 0.9rem;">+91 91234 56789<br>0612 - 2345678 (Mon-Sat 8:00 AM - 2:00 PM)</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Contact Form -->
      <div class="col-lg-7">
        <div class="glass-card shadow-lg border border-secondary p-4">
          <h4 class="text-white font-weight-bold mb-4"><i class="fa-solid fa-envelope-open-text text-info me-2"></i>Send Online Message</h4>
          
          <form onsubmit="event.preventDefault(); alert('Message successfully sent! Our administrative desk will reach out soon.'); this.reset();">
            <div class="row g-3">
              <div class="col-md-6">
                <label for="name" class="glass-label">Full Name</label>
                <input type="text" id="name" class="form-control glass-input" placeholder="Your Name" required>
              </div>
              <div class="col-md-6">
                <label for="email" class="glass-label">Email Address</label>
                <input type="email" id="email" class="form-control glass-input" placeholder="you@example.com" required>
              </div>
              <div class="col-12">
                <label for="subject" class="glass-label">Subject</label>
                <input type="text" id="subject" class="form-control glass-input" placeholder="e.g. Class 9 Admission query" required>
              </div>
              <div class="col-12 mb-3">
                <label for="msg" class="glass-label">Message Details</label>
                <textarea id="msg" class="form-control glass-input" rows="4" placeholder="Briefly describe your question here..." required></textarea>
              </div>
              <div class="col-12">
                <button type="submit" class="btn btn-tvm-primary w-100 py-3 font-weight-bold text-uppercase">
                  <i class="fa-solid fa-paper-plane me-2"></i>Submit Message
                </button>
              </div>
            </div>
          </form>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- Footer -->
<footer class="py-5" style="border-top: 1px solid var(--border-glass);">
  <div class="container text-center">
    <p class="text-secondary mb-0" style="font-size: 0.8rem;">&copy; 2026 TVM Public School Patna. All Rights Reserved.</p>
  </div>
</footer>

