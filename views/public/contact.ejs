      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="publicNav">
      <ul class="navbar-nav ms-auto mb-2 mb-lg-0 align-items-center">
        <li class="nav-item"><a class="nav-link nav-link-tvm" href="/">Home</a></li>
        <li class="nav-item"><a class="nav-link nav-link-tvm" href="/about">About</a></li>
        <li class="nav-item"><a class="nav-link nav-link-tvm" href="/facilities">Facilities</a></li>
        <li class="nav-item"><a class="nav-link nav-link-tvm" href="/faculty">Faculty</a></li>
        <li class="nav-item"><a class="nav-link nav-link-tvm" href="/gallery">Gallery</a></li>
        <li class="nav-item"><a class="nav-link nav-link-tvm" href="/events">Events</a></li>
