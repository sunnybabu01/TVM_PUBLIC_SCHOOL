<%- include('../partials/header') %>

<!-- Top Navigation -->
<nav class="navbar navbar-expand-lg navbar-dark navbar-tvm sticky-top">
  <div class="container">
    <a class="navbar-brand navbar-brand-tvm" href="/">
      <i class="fa-solid fa-graduation-cap text-info me-2"></i>TVM PUBLIC SCHOOL
    </a>
    <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#publicNav">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="publicNav">
      <ul class="navbar-nav ms-auto mb-2 mb-lg-0 align-items-center">
        <li class="nav-item"><a class="nav-link nav-link-tvm active" href="/">Home</a></li>
        <li class="nav-item"><a class="nav-link nav-link-tvm" href="/about">About</a></li>
        <li class="nav-item"><a class="nav-link nav-link-tvm" href="/facilities">Facilities</a></li>
        <li class="nav-item"><a class="nav-link nav-link-tvm" href="/faculty">Faculty</a></li>
        <li class="nav-item"><a class="nav-link nav-link-tvm" href="/gallery">Gallery</a></li>
        <li class="nav-item"><a class="nav-link nav-link-tvm" href="/events">Events</a></li>
        <li class="nav-item"><a class="nav-link nav-link-tvm" href="/contact">Contact</a></li>
        <li class="nav-item ms-lg-3 mt-2 mt-lg-0">
          <% if (user) { %>
            <% if (user.role === 'admin') { %>
              <a class="btn btn-tvm-primary px-4" href="/admin/dashboard"><i class="fa-solid fa-gauge me-2"></i>Dashboard</a>
            <% } else if (user.role === 'teacher') { %>
              <a class="btn btn-tvm-primary px-4" href="/teacher/dashboard"><i class="fa-solid fa-gauge me-2"></i>Dashboard</a>
            <% } else if (user.role === 'student') { %>
              <a class="btn btn-tvm-primary px-4" href="/student/dashboard"><i class="fa-solid fa-gauge me-2"></i>Dashboard</a>
            <% } %>
          <% } else { %>
            <a class="btn btn-tvm-primary px-4" href="/login"><i class="fa-solid fa-arrow-right-to-bracket me-2"></i>ERP Portal</a>
          <% } %>
        </li>
      </ul>
    </div>
  </div>
</nav>

<!-- Hero & Sliding Photos Carousel Section -->
<section class="py-5 my-md-4">
  <div class="container">
    <div class="row align-items-center g-5">
      
      <!-- Left Column: Inspiring Text & CTAs -->
      <div class="col-lg-6 text-center text-lg-start animate-fade-in-up">
        <span class="badge text-uppercase mb-3 px-3 py-2 font-weight-bold" style="background: rgba(0,242,254,0.1); color: var(--accent-cyan); border: 1px solid rgba(0,242,254,0.2);">
          🌟 Patna's Top Tech-Enabled Digital Campus
        </span>
        <h1 class="display-4 text-white font-weight-black mb-4" style="line-height: 1.2; font-weight: 800;">
          Nurturing Excellence, <br>
          <span class="gradient-text">Empowering Tomorrow's</span> Leaders
        </h1>
        <p class="text-secondary fs-5 mb-5" style="line-height: 1.8;">
          Welcome to **TVM Public School, Patna**—where academic excellence meets futuristic co-curricular design. We inspire students to achieve top-tier board scores while fostering deep interest in science, sports, and fine arts.
        </p>
        <div class="d-flex flex-column flex-sm-row justify-content-center justify-content-lg-start gap-3">
          <a href="/login" class="btn btn-tvm-primary px-5 py-3 text-uppercase font-weight-bold">
            <i class="fa-solid fa-door-open me-2"></i>Enter ERP Portal
          </a>
          <a href="#activities" class="btn btn-tvm-secondary px-5 py-3">
            Student Activities <i class="fa-solid fa-circle-arrow-down ms-2 text-info"></i>
          </a>
        </div>
      </div>
      
      <!-- Right Column: Majestic Glowing Photo Slider (Carousel) -->
      <div class="col-lg-6 animate-fade-in-up delay-200">
        <div class="carousel-glowing-frame p-2">
          <div id="tvmSchoolCarousel" class="carousel slide carousel-fade" data-bs-ride="carousel" data-bs-interval="4000">
            <!-- Carousel Indicators -->
            <div class="carousel-indicators">
              <button type="button" data-bs-target="#tvmSchoolCarousel" data-bs-slide-to="0" class="active" aria-current="true" aria-label="Sports Championship"></button>
              <button type="button" data-bs-target="#tvmSchoolCarousel" data-bs-slide-to="1" aria-label="Science Innovation"></button>
              <button type="button" data-bs-target="#tvmSchoolCarousel" data-bs-slide-to="2" aria-label="Cultural Festival"></button>
              <button type="button" data-bs-target="#tvmSchoolCarousel" data-bs-slide-to="3" aria-label="Academic Toppers"></button>
            </div>
            
            <!-- Slides -->
            <div class="carousel-inner" style="border-radius: 16px;">
              
              <!-- Slide 1: Sports Day -->
              <div class="carousel-item active">
                <img src="/images/sports_day.png" class="d-block w-100" alt="TVM Public School Sports Day" style="object-fit: cover; height: 420px;">
                <div class="carousel-caption carousel-caption-glass text-start px-4">
                  <h5 class="text-white font-weight-bold mb-1"><i class="fa-solid fa-trophy text-warning me-2"></i>Annual Sports Championship</h5>
                  <p class="text-secondary small mb-0">Unleashing agility, strength, and sportsmanship. Our track and field athletes secure state-level medals every year.</p>
                </div>
              </div>
              
              <!-- Slide 2: Science Lab -->
              <div class="carousel-item">
                <img src="/images/science_exhibit.png" class="d-block w-100" alt="TVM Science & Technology Exhibit" style="object-fit: cover; height: 420px;">
                <div class="carousel-caption carousel-caption-glass text-start px-4">
                  <h5 class="text-white font-weight-bold mb-1"><i class="fa-solid fa-flask-vial text-info me-2"></i>Science & Tech Innovation</h5>
                  <p class="text-secondary small mb-0">Students participating in interactive practical exhibits, building smart robotic models and coding digital software.</p>
                </div>
              </div>
              
              <!-- Slide 3: Cultural Fest -->
              <div class="carousel-item">
                <img src="/images/cultural_fest.png" class="d-block w-100" alt="TVM Cultural Annual Day" style="object-fit: cover; height: 420px;">
                <div class="carousel-caption carousel-caption-glass text-start px-4">
                  <h5 class="text-white font-weight-bold mb-1"><i class="fa-solid fa-guitar text-danger me-2"></i>Annual Cultural Day</h5>
                  <p class="text-secondary small mb-0">Expressing artistic grace and cultural heritage through captivating traditional dance, theatrical acts, and musical symphonies.</p>
                </div>
              </div>

              <!-- Slide 4: Academic Topper -->
              <div class="carousel-item">
                <img src="/images/student_star.png" class="d-block w-100" alt="TVM Academic Topper" style="object-fit: cover; height: 420px;">
                <div class="carousel-caption carousel-caption-glass text-start px-4">
                  <h5 class="text-white font-weight-bold mb-1"><i class="fa-solid fa-star text-warning me-2"></i>Inspiring Academic Excellence</h5>
                  <p class="text-secondary small mb-0">Our students achieve stellar academic landmarks, securing state-level ranks and top scores in secondary board examinations.</p>
                </div>
              </div>
              
            </div>
            
            <!-- Slider Navigation controls -->
            <button class="carousel-control-prev" type="button" data-bs-target="#tvmSchoolCarousel" data-bs-slide="prev">
              <span class="carousel-control-prev-icon" aria-hidden="true"></span>
              <span class="visually-hidden">Previous</span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#tvmSchoolCarousel" data-bs-slide="next">
              <span class="carousel-control-next-icon" aria-hidden="true"></span>
              <span class="visually-hidden">Next</span>
            </button>
          </div>
        </div>
      </div>
      
    </div>
  </div>
</section>

<!-- Extracurricular Activities Section (Beyond Academics) -->
<section id="activities" class="py-5" style="border-top: 1px solid var(--border-glass);">
  <div class="container text-center mb-5 animate-fade-in-up">
    <span class="badge text-uppercase mb-2 px-3 py-1 font-weight-bold" style="background: rgba(127,0,255,0.1); color: #7F00FF; border: 1px solid rgba(127,0,255,0.2);">Co-Curriculars</span>
    <h2 class="text-white font-weight-black" style="font-weight: 800;">Co-Curricular & Student Life</h2>
    <p class="text-secondary col-md-8 mx-auto">We provide robust pathways for students to explore their creative sparks, mechanical skills, physical prowess, and social responsibilities through active student clubs.</p>
  </div>
  
  <div class="container animate-fade-in-up delay-100">
    <div class="row g-4">
      
      <!-- Card 1: Sports -->
      <div class="col-md-4">
        <div class="glass-card hover-glow-card card-cyan h-100 d-flex flex-column text-start">
          <div class="d-flex align-items-center gap-3 mb-3">
            <span class="p-3 bg-info bg-opacity-15 rounded-circle border border-info border-opacity-25 text-info">
              <i class="fa-solid fa-person-running fs-4"></i>
            </span>
            <h5 class="text-white mb-0 font-weight-bold">Sports & Athletics</h5>
          </div>
          <p class="text-secondary flex-grow-1" style="font-size: 0.95rem;">
            From basketball tournaments to indoor badminton complexes, we offer expert coaching, structured physical education drills, and annual athletic games.
          </p>
          <div class="mt-3">
            <span class="badge bg-secondary bg-opacity-20 text-info">Football Club</span>
            <span class="badge bg-secondary bg-opacity-20 text-info">Athletics</span>
          </div>
        </div>
      </div>
      
      <!-- Card 2: Science & Tech -->
      <div class="col-md-4">
        <div class="glass-card hover-glow-card card-purple h-100 d-flex flex-column text-start">
          <div class="d-flex align-items-center gap-3 mb-3">
            <span class="p-3 bg-warning bg-opacity-15 rounded-circle border border-warning border-opacity-25 text-warning">
              <i class="fa-solid fa-laptop-code fs-4"></i>
            </span>
            <h5 class="text-white mb-0 font-weight-bold">Robotics & Tech Clubs</h5>
          </div>
          <p class="text-secondary flex-grow-1" style="font-size: 0.95rem;">
            Inspiring futuristic thinking! Students explore STEM through coding bootcamps, hands-on physics/chemistry labs, smart electronics modeling, and AI exhibitions.
          </p>
          <div class="mt-3">
            <span class="badge bg-secondary bg-opacity-20 text-warning">Coding Club</span>
            <span class="badge bg-secondary bg-opacity-20 text-warning">Robotics Kit</span>
          </div>
        </div>
      </div>
      
      <!-- Card 3: Performing Arts -->
      <div class="col-md-4">
        <div class="glass-card hover-glow-card card-emerald h-100 d-flex flex-column text-start">
          <div class="d-flex align-items-center gap-3 mb-3">
            <span class="p-3 bg-danger bg-opacity-15 rounded-circle border border-danger border-opacity-25 text-danger">
              <i class="fa-solid fa-masks-theater fs-4"></i>
            </span>
            <h5 class="text-white mb-0 font-weight-bold">Arts, Dance & Music</h5>
          </div>
          <p class="text-secondary flex-grow-1" style="font-size: 0.95rem;">
            Nurturing artistic excellence! Students participate in regional dance programs, theatre fests, classical instrumental music rooms, and fine arts championships.
          </p>
          <div class="mt-3">
            <span class="badge bg-secondary bg-opacity-20 text-danger">Classical Dance</span>
            <span class="badge bg-secondary bg-opacity-20 text-danger">Theatre</span>
          </div>
        </div>
      </div>
      
    </div>
  </div>
</section>

<!-- Academic Toppers / Shining Stars Section -->
<section class="py-5" style="border-top: 1px solid var(--border-glass);">
  <div class="container text-center mb-5 animate-fade-in-up">
    <span class="badge text-uppercase mb-2 px-3 py-1 font-weight-bold" style="background: rgba(0, 242, 254, 0.1); color: var(--accent-cyan); border: 1px solid rgba(0, 242, 254, 0.2);">Shining Stars</span>
    <h2 class="text-white font-weight-black" style="font-weight: 800;">Academic Excellence & Stars of TVM</h2>
    <p class="text-secondary col-md-8 mx-auto">Celebrating the outstanding achievements of our brilliant students who make TVM Public School proud in both academics and innovation.</p>
  </div>

  <div class="container animate-fade-in-up delay-100">
    <div class="row justify-content-center g-4">
      <% if (toppers && toppers.length > 0) { %>
        <% toppers.forEach(topper => { %>
          <div class="col-lg-6 col-md-12 d-flex">
            <div class="glass-card hover-glow-card card-cyan p-4 text-start w-100 d-flex flex-column justify-content-between" style="background: rgba(15, 23, 42, 0.7); border: 1px solid var(--border-glass); border-radius: 20px;">
              <div class="row align-items-center g-3 h-100">
                <div class="col-md-5 text-center d-flex align-items-center justify-content-center h-100">
                  <img src="<%= topper.photo %>" alt="<%= topper.name %>" class="img-fluid rounded shadow-lg border border-secondary" style="max-height: 220px; object-fit: cover; border-radius: 16px !important; width: 100%;">
                </div>
                <div class="col-md-7 d-flex flex-column justify-content-between h-100">
                  <div>
                    <span class="badge bg-info bg-opacity-20 text-info mb-2"><i class="fa-solid fa-trophy text-warning me-1"></i>Board Topper</span>
                    <h3 class="text-white font-weight-bold mb-1" style="font-size: 1.4rem;"><%= topper.name %></h3>
                    <p class="text-secondary font-weight-bold mb-2" style="color: var(--accent-cyan) !important; font-size: 0.9rem;"><%= topper.className %> | <%= topper.marks %></p>
                    <p class="text-secondary mb-3" style="line-height: 1.6; font-size: 0.85rem; font-style: italic;">
                      "<%= topper.testimonial %>"
                    </p>
                  </div>
                  <div class="d-flex align-items-center gap-2 mt-auto">
                    <i class="fa-solid fa-quote-left text-info fs-4 opacity-25"></i>
                    <small class="text-muted"><%= topper.name %>, TVM Class of <%= new Date(topper.createdAt).getFullYear() %></small>
                  </div>
                </div>
              </div>
            </div>
          </div>
        <% }) %>
      <% } else { %>
        <div class="col-lg-8">
          <div class="glass-card hover-glow-card card-cyan p-4 p-md-5 text-start" style="background: rgba(15, 23, 42, 0.7); border: 1px solid var(--border-glass); border-radius: 20px;">
            <div class="row align-items-center g-4">
              <div class="col-md-5 text-center">
                <img src="/images/student_star.png" alt="TVM Academic Topper" class="img-fluid rounded shadow-lg border border-secondary" style="max-height: 280px; object-fit: cover; border-radius: 16px !important;">
              </div>
              <div class="col-md-7">
                <span class="badge bg-info bg-opacity-20 text-info mb-2"><i class="fa-solid fa-trophy text-warning me-1"></i>CBSE Board Topper</span>
                <h3 class="text-white font-weight-bold mb-1">Aarav Sharma</h3>
                <p class="text-secondary font-weight-bold mb-3" style="color: var(--accent-cyan) !important;">Class X | 98.6% CBSE Board Examinations</p>
                <p class="text-secondary mb-4" style="line-height: 1.7; font-size: 0.95rem;">
                  "TVM Public School's interactive smart labs and outstanding mentor faculty gave me the perfect foundation to excel in my board exams while allowing me to actively pursue robotics and coding club projects."
                </p>
                <div class="d-flex align-items-center gap-2">
                  <i class="fa-solid fa-quote-left text-info fs-3 opacity-25"></i>
                  <small class="text-muted">Aarav Sharma, TVM Class of 2026</small>
                </div>
              </div>
            </div>
          </div>
        </div>
      <% } %>
    </div>
  </div>
</section>

<!-- Stats & Announcements Section -->
<section class="py-5" style="background: rgba(255, 255, 255, 0.01); border-top: 1px solid var(--border-glass); border-bottom: 1px solid var(--border-glass);">
  <div class="container">
    <div class="row g-5">
      
      <!-- Stats -->
      <div class="col-lg-6">
        <h3 class="text-white font-weight-bold mb-4"><i class="fa-solid fa-chart-line text-info me-2"></i>TVM At A Glance</h3>
        <div class="row g-3">
          <div class="col-sm-6">
            <div class="glass-card text-center card-cyan">
              <h2 class="display-6 font-weight-black text-white mb-1">100%</h2>
              <p class="text-secondary mb-0">CBSE Board Success</p>
            </div>
          </div>
          <div class="col-sm-6">
            <div class="glass-card text-center card-purple">
              <h2 class="display-6 font-weight-black text-white mb-1">40+</h2>
              <p class="text-secondary mb-0">Expert Mentors</p>
            </div>
          </div>
          <div class="col-sm-6">
            <div class="glass-card text-center card-emerald">
              <h2 class="display-6 font-weight-black text-white mb-1">15+</h2>
              <p class="text-secondary mb-0">Sports & Activities</p>
            </div>
          </div>
          <div class="col-sm-6">
            <div class="glass-card text-center">
              <h2 class="display-6 font-weight-black text-white mb-1">1500+</h2>
              <p class="text-secondary mb-0">Alumni Network</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Announcements Ticker -->
      <div class="col-lg-6">
        <h3 class="text-white font-weight-bold mb-4"><i class="fa-solid fa-bullhorn text-warning me-2"></i>Recent Announcements</h3>
        <div class="glass-card p-4" style="background: rgba(15, 23, 42, 0.7); max-height: 380px; overflow-y: auto;">
          <% if (announcements.length === 0) { %>
            <div class="text-center text-muted py-5">
              <i class="fa-regular fa-bell-slash fs-1 mb-3"></i>
              <p class="mb-0">No active general announcements at this time.</p>
            </div>
          <% } else { %>
            <ul class="list-unstyled mb-0">
              <% announcements.forEach((notice, idx) => { %>
                <li class="mb-3 pb-3 <%= idx < announcements.length - 1 ? 'border-bottom border-secondary' : '' %>">
                  <div class="d-flex justify-content-between align-items-center mb-1">
                    <h6 class="text-info font-weight-bold mb-0"><%= notice.title %></h6>
                    <small class="text-muted"><%= new Date(notice.createdAt).toLocaleDateString('en-IN') %></small>
                  </div>
                  <p class="text-secondary mb-0" style="font-size: 0.9rem; white-space: pre-line;"><%= notice.content %></p>
                </li>
              <% }) %>
            </ul>
          <% } %>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- Footer -->
<footer class="py-5" style="border-top: 1px solid var(--border-glass);">
  <div class="container text-center">
    <p class="text-white font-weight-bold mb-2">TVM Public School, Patna</p>
    <p class="text-muted mb-4" style="font-size: 0.9rem;">Affiliated with Central Board of Secondary Education (CBSE)</p>
    <p class="text-secondary mb-0" style="font-size: 0.8rem;">&copy; 2026 TVM Public School Patna. All Rights Reserved. Designed by Antigravity AI.</p>
  </div>
</footer>

<%- include('../partials/footer') %>
