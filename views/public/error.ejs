<%- include('../partials/header') %>

<div class="login-body" style="background-image: linear-gradient(180deg, #090d1a 0%, #0c1122 100%);">
  <div class="ambient-bubble bubble-1" style="background: var(--accent-sunset); opacity: 0.1;"></div>
  <div class="ambient-bubble bubble-2" style="background: var(--accent-purple); opacity: 0.1;"></div>
  
  <div class="container d-flex justify-content-center align-items-center">
    <div class="glass-card px-4 py-5 shadow-lg border border-secondary text-center" style="background: rgba(15, 23, 42, 0.7); max-width: 500px;">
      
      <!-- Cosmic Error Grid Icon -->
      <div class="mb-4">
        <span class="d-inline-block rounded-circle bg-danger bg-opacity-10 p-4 border border-danger border-opacity-25" style="animation: pulseError 2s infinite;">
          <i class="fa-solid fa-triangle-exclamation text-danger fs-1"></i>
        </span>
      </div>

      <style>
        @keyframes pulseError {
          0% { transform: scale(1); box-shadow: 0 0 0 0 rgba(220, 38, 38, 0.2); }
          70% { transform: scale(1.05); box-shadow: 0 0 0 15px rgba(220, 38, 38, 0); }
          100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(220, 38, 38, 0); }
        }
      </style>

      <!-- Glowing Status -->
      <h1 class="display-3 font-weight-black text-white mb-2" style="text-shadow: 0 0 20px rgba(239, 68, 68, 0.5);"><%= errorCode %></h1>
      <h3 class="text-white mb-3 font-weight-bold" style="font-size: 1.4rem;"><%= title %></h3>
      
      <!-- Error Message -->
      <p class="text-secondary mb-4" style="font-size: 0.95rem; line-height: 1.6;">
        <%= errorMessage %>
      </p>

      <!-- Redirection buttons -->
      <div class="d-flex flex-column flex-sm-row justify-content-center gap-3">
        <a href="/" class="btn btn-tvm-primary px-4 py-2 font-weight-bold">
          <i class="fa-solid fa-house-chimney me-2"></i>Go to Home
        </a>
        <% if (user) { %>
          <a href="/logout" class="btn btn-tvm-secondary px-4 py-2">
            <i class="fa-solid fa-power-off me-2 text-danger"></i>Log Out
          </a>
        <% } else { %>
          <a href="/login" class="btn btn-tvm-secondary px-4 py-2">
            <i class="fa-solid fa-arrow-right-to-bracket me-2 text-info"></i>Go to Login
          </a>
        <% } %>
      </div>

      <div class="mt-4 border-top border-secondary pt-3">
        <small class="text-muted" style="font-size: 0.75rem;">
          TVM Public School Portal Support &copy; 2026.
        </small>
      </div>

    </div>
  </div>
</div>

<%- include('../partials/footer') %>
