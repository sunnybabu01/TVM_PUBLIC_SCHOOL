<%- include('../partials/header') %>

<div class="dashboard-layout">
  
  <!-- Sidebar -->
  <%- include('../partials/sidebar') %>
  
  <!-- Main Contents -->
  <main class="main-content-tvm">
    
    <!-- Top Nav Navbar -->
    <%- include('../partials/navbar') %>
    
    <!-- Session Messages -->
    <%- include('../partials/messages') %>
    
    <div class="container-fluid p-0">
      
      <!-- Welcome Banner -->
      <div class="row mb-4">
        <div class="col-12 d-flex justify-content-between align-items-center flex-wrap gap-3">
          <div>
            <h2 class="text-white font-weight-bold mb-1">Lab Assets & School Inventory</h2>
            <p class="text-secondary mb-0">Track furniture, lab setups, scientific equipment, classrooms stocks and computer labs supplies.</p>
          </div>
          <button class="btn btn-tvm-primary" data-bs-toggle="modal" data-bs-target="#addInventoryModal">
            <i class="fa-solid fa-plus me-2"></i>Register New Asset
          </button>
        </div>
      </div>

      <!-- Quick Statistics Cards Grid -->
      <div class="row g-4 mb-4">
        <div class="col-md-3">
          <div class="glass-card shadow-lg card-cyan">
            <div class="d-flex justify-content-between align-items-center mb-2">
              <span class="text-secondary font-weight-bold">UNIQUE ITEMS</span>
              <i class="fa-solid fa-warehouse text-info fs-4"></i>
            </div>
            <h3 class="text-white display-6 font-weight-black mb-0"><%= items.length %></h3>
          </div>
        </div>
        <div class="col-md-3">
          <div class="glass-card shadow-lg card-emerald">
            <div class="d-flex justify-content-between align-items-center mb-2">
              <span class="text-secondary font-weight-bold">TOTAL QUANTITY</span>
              <i class="fa-solid fa-cubes text-success fs-4"></i>
            </div>
            <h3 class="text-white display-6 font-weight-black mb-0">
              <%= items.reduce((acc, curr) => acc + curr.quantity, 0) %>
            </h3>
          </div>
        </div>
        <div class="col-md-3">
          <div class="glass-card shadow-lg card-purple">
            <div class="d-flex justify-content-between align-items-center mb-2">
              <span class="text-secondary font-weight-bold">LAB EQUIPMENT</span>
              <i class="fa-solid fa-flask text-warning fs-4"></i>
            </div>
            <h3 class="text-white display-6 font-weight-black mb-0">
              <%= items.filter(i => i.category === 'Lab Equipment').reduce((acc, curr) => acc + curr.quantity, 0) %>
            </h3>
          </div>
        </div>
        <div class="col-md-3">
          <div class="glass-card shadow-lg">
            <div class="d-flex justify-content-between align-items-center mb-2">
              <span class="text-secondary font-weight-bold">NEEDS REPAIR/BROKEN</span>
              <i class="fa-solid fa-triangle-exclamation text-danger fs-4"></i>
            </div>
            <h3 class="text-white display-6 font-weight-black mb-0 text-danger">
              <%= items.filter(i => i.condition === 'Needs Repair' || i.condition === 'Broken').length %>
            </h3>
          </div>
        </div>
      </div>

      <!-- Inventory Catalogue List -->
      <div class="row">
        <div class="col-12">
          <div class="glass-card shadow-lg">
            <h5 class="text-white font-weight-bold mb-4"><i class="fa-solid fa-clipboard-list text-info me-2"></i>Physical Asset Log</h5>
            
            <div class="table-responsive">
              <table class="tvm-table">
                <thead>
                  <tr>
                    <th>Item Name</th>
                    <th>Category</th>
                    <th>Stock Qty</th>
                    <th>Room / Lab Location</th>
                    <th>Physical Condition</th>
                    <th>Last Updated By</th>
                    <th>Status</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (items.length === 0) { %>
                    <tr>
                      <td colspan="7" class="text-center py-4 text-muted">No inventory records compiled yet. Add your first asset.</td>
                    </tr>
                  <% } else { %>
                    <% items.forEach(item => { %>
                      <tr>
                        <td class="font-weight-bold text-white"><%= item.itemName %></td>
                        <td><span class="badge bg-dark border border-secondary text-secondary"><%= item.category %></span></td>
                        <td class="text-white font-weight-bold"><%= item.quantity %> Units</td>
                        <td><i class="fa-solid fa-location-dot text-info me-2"></i><%= item.roomNo %></td>
                        <td>
                          <% if (item.condition === 'Excellent') { %>
                            <span class="status-badge status-present">Excellent</span>
                          <% } else if (item.condition === 'Good') { %>
                            <span class="status-badge status-active">Good</span>
                          <% } else if (item.condition === 'Needs Repair') { %>
                            <span class="status-badge status-late">Needs Repair</span>
                          <% } else { %>
                            <span class="status-badge status-absent">Broken</span>
                          <% } %>
                        </td>
                        <td><small class="text-secondary"><%= item.lastUpdatedBy %></small></td>
                        <td>
                          <% if (item.quantity > 0) { %>
                            <span class="text-success"><i class="fa-solid fa-circle-check me-1"></i> Stocked</span>
                          <% } else { %>
                            <span class="text-danger"><i class="fa-solid fa-circle-xmark me-1"></i> Out of Stock</span>
                          <% } %>
                        </td>
                      </tr>
                    <% }) %>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>

    </div>
  </main>
</div>

<!-- Add Inventory Modal -->
<div class="modal fade" id="addInventoryModal" tabindex="-1" aria-labelledby="addInventoryModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content bg-dark border border-secondary text-white">
      <div class="modal-header border-secondary">
        <h5 class="modal-title font-weight-bold" id="addInventoryModalLabel">Register Physical Asset</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form action="/admin/inventory/add" method="POST">
        <div class="modal-body">
          <div class="mb-3">
            <label class="glass-label">Asset / Item Name</label>
            <input type="text" name="itemName" class="form-control glass-input" required placeholder="e.g. Dell Optiplex Dual Monitor Station">
          </div>
          <div class="mb-3">
            <label class="glass-label">Category</label>
            <select name="category" class="form-select glass-input" required>
              <option value="Lab Equipment">Lab Equipment</option>
              <option value="Furniture">Furniture</option>
              <option value="Electronics">Electronics</option>
              <option value="Sports">Sports</option>
              <option value="Classroom Supplies">Classroom Supplies</option>
              <option value="Office Supplies">Office Supplies</option>
            </select>
          </div>
          <div class="mb-3">
            <label class="glass-label">Physical Quantity</label>
            <input type="number" name="quantity" class="form-control glass-input" required min="1" value="10">
          </div>
          <div class="mb-3">
            <label class="glass-label">Room No / Lab Location</label>
            <input type="text" name="roomNo" class="form-control glass-input" required placeholder="e.g. Physics Lab (Block A - Room 102)">
          </div>
          <div class="mb-3">
            <label class="glass-label">Initial Condition State</label>
            <select name="condition" class="form-select glass-input">
              <option value="Excellent">Excellent</option>
              <option value="Good" selected>Good</option>
              <option value="Needs Repair">Needs Repair</option>
              <option value="Broken">Broken</option>
            </select>
          </div>
        </div>
        <div class="modal-footer border-secondary">
          <button type="button" class="btn btn-tvm-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-tvm-primary">Add Asset</button>
        </div>
      </form>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
