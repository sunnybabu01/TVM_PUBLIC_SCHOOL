<%- include('../partials/header') %>

<div class="dashboard-layout">
  <%- include('../partials/sidebar') %>
  
  <main class="main-content-tvm">
    <%- include('../partials/navbar') %>
    <%- include('../partials/messages') %>
    
    <div class="container-fluid p-0">
      
      <!-- Header -->
      <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
          <h2 class="text-white font-weight-bold mb-1">Faculty Administration</h2>
          <p class="text-secondary mb-0" style="font-size: 0.9rem;">Provision credentials, map subjects, edit profiles, and regulate school educators.</p>
        </div>
        <button class="btn btn-tvm-primary px-4 py-3" data-bs-toggle="modal" data-bs-target="#addTeacherModal">
          <i class="fa-solid fa-plus me-2"></i>Provision Teacher Account
        </button>
      </div>

      <!-- Main Directory Card -->
      <div class="glass-card shadow-lg">
        <div class="table-responsive">
          <table class="tvm-table">
            <thead>
              <tr>
                <th>Teacher ID</th>
                <th>Full Name</th>
                <th>Registered Email</th>
                <th>Assigned Subject</th>
                <th>Contact Phone</th>
                <th>Date Joined</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if (teachers.length === 0) { %>
                <tr>
                  <td colspan="7" class="text-center py-5 text-muted">
                    <i class="fa-solid fa-people-roof fs-2 d-block mb-3 text-info"></i>
                    No faculty members registered in school database yet.
                  </td>
                </tr>
              <% } else { %>
                <% teachers.forEach(teacher => { %>
                  <tr>
                    <td class="text-white font-weight-bold"><%= teacher.teacherId %></td>
                    <td><%= teacher.name %></td>
                    <td><%= teacher.email %></td>
                    <td><span class="badge bg-secondary py-2 px-3"><%= teacher.subject %></span></td>
                    <td><%= teacher.phone || 'N/A' %></td>
                    <td><%= new Date(teacher.createdAt).toLocaleDateString('en-IN') %></td>
                    <td>
                      <div class="d-flex gap-2">
                        <!-- Edit Button -->
                        <button class="btn btn-tvm-secondary btn-sm edit-teacher-btn" 
                                data-id="<%= teacher._id %>"
                                data-name="<%= teacher.name %>"
                                data-email="<%= teacher.email %>"
                                data-subject="<%= teacher.subject %>"
                                data-phone="<%= teacher.phone %>"
                                data-bs-toggle="modal" 
                                data-bs-target="#editTeacherModal"
                                title="Edit Records">
                          <i class="fa-solid fa-pencil text-info"></i>
                        </button>
                        
                        <!-- Delete form -->
                        <form action="/admin/teachers/delete/<%= teacher._id %>" method="POST" onsubmit="return confirm('Attention! Deleting this teacher record will permanently erase their access credentials. Are you sure?');" style="display:inline;">
                          <button type="submit" class="btn btn-tvm-secondary btn-sm" title="Delete Profile">
                            <i class="fa-solid fa-trash-can text-danger"></i>
                          </button>
                        </form>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

    </div>
  </main>
</div>

<!-- ================= MODAL: PROVISION TEACHER ================= -->
<div class="modal fade" id="addTeacherModal" tabindex="-1" aria-labelledby="addTeacherLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content glass-card border border-secondary" style="background: var(--bg-slate);">
      <div class="modal-header border-bottom border-secondary">
        <h5 class="modal-title text-white font-weight-bold" id="addTeacherLabel"><i class="fa-solid fa-user-plus text-info me-2"></i>Provision Teacher Credentials</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form action="/admin/teachers/add" method="POST">
        <div class="modal-body">
          <div class="row g-3">
            <div class="col-12">
              <label for="addTeacherName" class="glass-label">Teacher Full Name</label>
              <input type="text" name="name" id="addTeacherName" class="form-control glass-input" placeholder="e.g. Prof. Rajesh Kumar" required>
            </div>
            
            <div class="col-12">
              <label for="addTeacherEmail" class="glass-label">Official Email</label>
              <input type="email" name="email" id="addTeacherEmail" class="form-control glass-input" placeholder="e.g. rajesh@tvm.com" required>
            </div>

            <div class="col-md-6">
              <label for="addTeacherSubject" class="glass-label">Assigned Subject</label>
              <select name="subject" id="addTeacherSubject" class="form-select glass-input text-white" style="background-color: var(--bg-core);" required>
                <option value="" disabled selected>Select Subject...</option>
                <option value="Mathematics">Mathematics</option>
                <option value="Physics">Physics</option>
                <option value="Chemistry">Chemistry</option>
                <option value="Computer Science">Computer Science</option>
                <option value="English">English</option>
              </select>
            </div>

            <div class="col-md-6">
              <label for="addTeacherPhone" class="glass-label">Phone Number</label>
              <input type="text" name="phone" id="addTeacherPhone" class="form-control glass-input" placeholder="Mobile phone" required>
            </div>

            <div class="col-12">
              <label for="addTeacherPassword" class="glass-label">Temporary Password (Optional)</label>
              <input type="text" name="password" id="addTeacherPassword" class="form-control glass-input" placeholder="Default is teacher123">
            </div>
          </div>
        </div>
        <div class="modal-footer border-top border-secondary">
          <button type="button" class="btn btn-tvm-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-tvm-primary">Activate Account & Send Mail</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- ================= MODAL: EDIT TEACHER ================= -->
<div class="modal fade" id="editTeacherModal" tabindex="-1" aria-labelledby="editTeacherLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content glass-card border border-secondary" style="background: var(--bg-slate);">
      <div class="modal-header border-bottom border-secondary">
        <h5 class="modal-title text-white font-weight-bold" id="editTeacherLabel"><i class="fa-solid fa-user-pen text-info me-2"></i>Modify Faculty Records</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form id="editTeacherForm" action="" method="POST">
        <div class="modal-body">
          <div class="row g-3">
            <div class="col-12">
              <label for="editTeacherName" class="glass-label">Teacher Full Name</label>
              <input type="text" name="name" id="editTeacherName" class="form-control glass-input" required>
            </div>
            
            <div class="col-12">
              <label for="editTeacherEmail" class="glass-label">Official Email</label>
              <input type="email" name="email" id="editTeacherEmail" class="form-control glass-input" required>
            </div>

            <div class="col-md-6">
              <label for="editTeacherSubject" class="glass-label">Assigned Subject</label>
              <select name="subject" id="editTeacherSubject" class="form-select glass-input text-white" style="background-color: var(--bg-core);" required>
                <option value="Mathematics">Mathematics</option>
                <option value="Physics">Physics</option>
                <option value="Chemistry">Chemistry</option>
                <option value="Computer Science">Computer Science</option>
                <option value="English">English</option>
              </select>
            </div>

            <div class="col-md-6">
              <label for="editTeacherPhone" class="glass-label">Phone Number</label>
              <input type="text" name="phone" id="editTeacherPhone" class="form-control glass-input" required>
            </div>
          </div>
        </div>
        <div class="modal-footer border-top border-secondary">
          <button type="button" class="btn btn-tvm-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-tvm-primary">Commit Changes</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Dynamic Teacher Filler JS -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const editButtons = document.querySelectorAll('.edit-teacher-btn');
    const editForm = document.getElementById('editTeacherForm');
    const editName = document.getElementById('editTeacherName');
    const editEmail = document.getElementById('editTeacherEmail');
    const editSubject = document.getElementById('editTeacherSubject');
    const editPhone = document.getElementById('editTeacherPhone');

    editButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        const id = btn.getAttribute('data-id');
        const name = btn.getAttribute('data-name');
        const email = btn.getAttribute('data-email');
        const subject = btn.getAttribute('data-subject');
        const phone = btn.getAttribute('data-phone');

        // Form action route
        editForm.action = `/admin/teachers/edit/${id}`;
        
        // Populate inputs
        editName.value = name;
        editEmail.value = email;
        editSubject.value = subject;
        editPhone.value = phone;
      });
    });
  });
</script>

<%- include('../partials/footer') %>
