<%- include('../partials/header') %>

<div class="dashboard-layout">
  <%- include('../partials/sidebar') %>
  
  <main class="main-content-tvm">
    <%- include('../partials/navbar') %>
    <%- include('../partials/messages') %>
    
    <div class="container-fluid p-0">
      
      <!-- Header -->
      <div class="mb-4">
        <h2 class="text-white font-weight-bold mb-1">Attendance Audits</h2>
        <p class="text-secondary mb-0" style="font-size: 0.9rem;">Review and audit student and faculty attendance records marked across classrooms.</p>
      </div>

      <!-- Audit Card -->
      <div class="glass-card shadow-lg">
        <div class="table-responsive">
          <table class="tvm-table">
            <thead>
              <tr>
                <th>Date</th>
                <th>Attendee Role</th>
                <th>Attendee ID / Name</th>
                <th>Status Marked</th>
                <th>Authorized By</th>
              </tr>
            </thead>
            <tbody>
              <% if (records.length === 0) { %>
                <tr>
                  <td colspan="5" class="text-center py-5 text-muted">
                    <i class="fa-solid fa-clipboard-question fs-2 d-block mb-3 text-warning"></i>
                    No attendance records registered yet. Teachers will mark attendance from their portals.
                  </td>
                </tr>
              <% } else { %>
                <% records.forEach(record => { %>
                  <tr>
                    <td class="text-white"><%= new Date(record.date).toLocaleDateString('en-IN') %></td>
                    <td>
                      <span class="badge text-uppercase py-2 px-3" style="background-color: <%= record.userRole === 'student' ? 'rgba(56, 249, 215, 0.15)' : 'rgba(127, 0, 255, 0.15)' %>; color: <%= record.userRole === 'student' ? '#38F9D7' : '#C084FC' %>;">
                        <%= record.userRole %>
                      </span>
                    </td>
                    <td class="font-weight-bold text-white"><%= record.userId %></td>
                    <td>
                      <% if (record.status === 'present') { %>
                        <span class="status-badge status-present">Present</span>
                      <% } else if (record.status === 'absent') { %>
                        <span class="status-badge status-absent">Absent</span>
                      <% } else if (record.status === 'late') { %>
                        <span class="status-badge status-late">Late</span>
                      <% } %>
                    </td>
                    <td><%= record.markedBy %></td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

    </div>
  </main>
</div>

<%- include('../partials/footer') %>
