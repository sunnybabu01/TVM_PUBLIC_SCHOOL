<%- include('../partials/header') %>

<div class="dashboard-layout">
  <%- include('../partials/sidebar') %>
  
  <main class="main-content-tvm">
    <%- include('../partials/navbar') %>
    <%- include('../partials/messages') %>
    
    <div class="container-fluid p-0">
      
      <!-- Header with Add button -->
      <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
          <h2 class="text-white font-weight-bold mb-1">Student Demographics</h2>
          <p class="text-secondary mb-0" style="font-size: 0.9rem;">Register, modify, delete, and view comprehensive student logs.</p>
        </div>
        <button class="btn btn-tvm-primary px-4 py-3" data-bs-toggle="modal" data-bs-target="#addStudentModal">
          <i class="fa-solid fa-plus me-2"></i>Register New Student
        </button>
      </div>

      <!-- Main Directory Glass Card -->
      <div class="glass-card shadow-lg">
        <div class="table-responsive">
          <table class="tvm-table">
            <thead>
              <tr>
                <th>Student ID</th>
                <th>Full Name</th>
                <th>Class - Section</th>
                <th>Roll Number</th>
                <th>Father's Name</th>
                <th>Status</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if (students.length === 0) { %>
                <tr>
                  <td colspan="7" class="text-center py-5 text-muted">
                    <i class="fa-regular fa-folder-open fs-2 d-block mb-3"></i>
                    No student records seeded yet. Registered students will list here.
                  </td>
                </tr>
              <% } else { %>
                <% students.forEach(student => { %>
                  <tr>
                    <td class="text-white font-weight-bold"><%= student.studentId %></td>
                    <td>
                      <div class="d-flex align-items-center gap-2">
                        <img src="<%= student.photo || '/uploads/default-avatar.png' %>" alt="<%= student.name %>" class="rounded-circle border border-secondary" style="width: 32px; height: 32px; object-fit: cover; background: transparent;">
                        <span><%= student.name %></span>
                      </div>
                    </td>
                    <td><%= student.className %> - <%= student.section %></td>
                    <td><%= student.rollNumber %></td>
                    <td><%= student.fatherName %></td>
                    <td>
                      <% if (student.status === 'active') { %>
                        <span class="status-badge status-present">Active</span>
                      <% } else { %>
                        <span class="status-badge status-absent">Inactive</span>
                      <% } %>
                    </td>
                    <td>
                      <div class="d-flex gap-2">
                        <!-- Edit Button carrying data-attributes -->
                        <button class="btn btn-tvm-secondary btn-sm edit-btn" 
                                data-id="<%= student._id %>"
                                data-name="<%= student.name %>"
                                data-email="<%= student.email %>"
                                data-class="<%= student.className %>"
                                data-section="<%= student.section %>"
                                data-roll="<%= student.rollNumber %>"
                                data-father="<%= student.fatherName %>"
                                data-status="<%= student.status %>"
                                data-photo="<%= student.photo %>"
                                data-bs-toggle="modal" 
                                data-bs-target="#editStudentModal"
                                title="Edit Records">
                          <i class="fa-solid fa-pencil text-info"></i>
                        </button>
                        
                        <!-- Delete form -->
                        <form action="/admin/students/delete/<%= student._id %>" method="POST" onsubmit="return confirm('Caution! Are you absolutely sure you want to permanently delete this student record from ERP database?');" style="display:inline;">
                          <button type="submit" class="btn btn-tvm-secondary btn-sm" title="Delete Profile">
                            <i class="fa-solid fa-trash-can text-danger"></i>
                          </button>
                        </form>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

    </div>
  </main>
</div>

<!-- ================= MODAL: REGISTER STUDENT ================= -->
<div class="modal fade" id="addStudentModal" tabindex="-1" aria-labelledby="addStudentLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content glass-card border border-secondary" style="background: var(--bg-slate);">
      <div class="modal-header border-bottom border-secondary">
        <h5 class="modal-title text-white font-weight-bold" id="addStudentLabel"><i class="fa-solid fa-user-plus text-info me-2"></i>Register New Student</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form action="/admin/students/add" method="POST" enctype="multipart/form-data">
        <div class="modal-body">
          <div class="row g-3">
            <div class="col-12 text-center mb-3">
              <div class="position-relative d-inline-block mx-auto mb-2">
                <img src="/uploads/default-avatar.png" id="addPhotoPreview" alt="Student Photo" class="rounded-circle border border-info img-thumbnail" style="width: 100px; height: 100px; object-fit: cover; background: transparent;">
                <label for="addPhoto" class="position-absolute bottom-0 end-0 bg-info text-dark rounded-circle border border-dark p-1 cursor-pointer hover-scale" style="width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; cursor: pointer;">
                  <i class="fa-solid fa-camera" style="font-size: 0.8rem;"></i>
                </label>
                <input type="file" name="photo" id="addPhoto" accept="image/png, image/jpeg, image/jpg" class="d-none">
              </div>
              <small class="text-muted d-block" style="font-size: 0.75rem;">Upload Student Photo (Optional)</small>
            </div>

            <div class="col-12">
              <label for="addName" class="glass-label">Student Full Name</label>
              <input type="text" name="name" id="addName" class="form-control glass-input" placeholder="e.g. Rahul Verma" required>
            </div>
            
            <div class="col-12">
              <label for="addEmail" class="glass-label">Registered Email</label>
              <input type="email" name="email" id="addEmail" class="form-control glass-input" placeholder="e.g. rahul@gmail.com" required>
            </div>

            <div class="col-md-6">
              <label for="addClass" class="glass-label">Class Name</label>
              <select name="className" id="addClass" class="form-select glass-input text-white" style="background-color: var(--bg-core);" required>
                <option value="" disabled selected>Select...</option>
                <option value="1">Class 1</option>
                <option value="2">Class 2</option>
                <option value="5">Class 5</option>
                <option value="9">Class 9</option>
                <option value="10">Class 10</option>
              </select>
            </div>

            <div class="col-md-6">
              <label for="addSection" class="glass-label">Section</label>
              <input type="text" name="section" id="addSection" class="form-control glass-input" placeholder="e.g. A, B" required>
            </div>

            <div class="col-md-6">
              <label for="addRoll" class="glass-label">Roll Number</label>
              <input type="number" name="rollNumber" id="addRoll" class="form-control glass-input" placeholder="e.g. 15" required>
            </div>

            <div class="col-md-6">
              <label for="addFather" class="glass-label">Father's Name</label>
              <input type="text" name="fatherName" id="addFather" class="form-control glass-input" placeholder="Father's name" required>
            </div>

            <div class="col-12">
              <label for="addPassword" class="glass-label">Temporary Password (Optional)</label>
              <input type="text" name="password" id="addPassword" class="form-control glass-input" placeholder="Default is student123">
            </div>
          </div>
        </div>
        <div class="modal-footer border-top border-secondary">
          <button type="button" class="btn btn-tvm-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-tvm-primary">Save and Provision ID</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- ================= MODAL: EDIT STUDENT ================= -->
<div class="modal fade" id="editStudentModal" tabindex="-1" aria-labelledby="editStudentLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content glass-card border border-secondary" style="background: var(--bg-slate);">
      <div class="modal-header border-bottom border-secondary">
        <h5 class="modal-title text-white font-weight-bold" id="editStudentLabel"><i class="fa-solid fa-user-pen text-info me-2"></i>Modify Student Records</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form id="editForm" action="" method="POST" enctype="multipart/form-data">
        <div class="modal-body">
          <div class="row g-3">
            <div class="col-12 text-center mb-3">
              <div class="position-relative d-inline-block mx-auto mb-2">
                <img src="/uploads/default-avatar.png" id="editPhotoPreview" alt="Student Photo" class="rounded-circle border border-info img-thumbnail" style="width: 100px; height: 100px; object-fit: cover; background: transparent;">
                <label for="editPhoto" class="position-absolute bottom-0 end-0 bg-info text-dark rounded-circle border border-dark p-1 cursor-pointer hover-scale" style="width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; cursor: pointer;">
                  <i class="fa-solid fa-camera" style="font-size: 0.8rem;"></i>
                </label>
                <input type="file" name="photo" id="editPhoto" accept="image/png, image/jpeg, image/jpg" class="d-none">
              </div>
              <small class="text-muted d-block" style="font-size: 0.75rem;">Modify Student Photo (Optional)</small>
            </div>

            <div class="col-12">
              <label for="editName" class="glass-label">Student Full Name</label>
              <input type="text" name="name" id="editName" class="form-control glass-input" required>
            </div>
            
            <div class="col-12">
              <label for="editEmail" class="glass-label">Registered Email</label>
              <input type="email" name="email" id="editEmail" class="form-control glass-input" required>
            </div>

            <div class="col-md-6">
              <label for="editClass" class="glass-label">Class Name</label>
              <select name="className" id="editClass" class="form-select glass-input text-white" style="background-color: var(--bg-core);" required>
                <option value="1">Class 1</option>
                <option value="2">Class 2</option>
                <option value="5">Class 5</option>
                <option value="9">Class 9</option>
                <option value="10">Class 10</option>
              </select>
            </div>

            <div class="col-md-6">
              <label for="editSection" class="glass-label">Section</label>
              <input type="text" name="section" id="editSection" class="form-control glass-input" required>
            </div>

            <div class="col-md-6">
              <label for="editRoll" class="glass-label">Roll Number</label>
              <input type="number" name="rollNumber" id="editRoll" class="form-control glass-input" required>
            </div>

            <div class="col-md-6">
              <label for="editFather" class="glass-label">Father's Name</label>
              <input type="text" name="fatherName" id="editFather" class="form-control glass-input" required>
            </div>

            <div class="col-12">
              <label for="editStatus" class="glass-label">Account Status</label>
              <select name="status" id="editStatus" class="form-select glass-input text-white" style="background-color: var(--bg-core);" required>
                <option value="active">Active</option>
                <option value="inactive">Inactive</option>
              </select>
            </div>
          </div>
        </div>
        <div class="modal-footer border-top border-secondary">
          <button type="button" class="btn btn-tvm-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-tvm-primary">Commit Changes</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Dynamic Modal Filler JS -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const editButtons = document.querySelectorAll('.edit-btn');
    const editForm = document.getElementById('editForm');
    const editName = document.getElementById('editName');
    const editEmail = document.getElementById('editEmail');
    const editClass = document.getElementById('editClass');
    const editSection = document.getElementById('editSection');
    const editRoll = document.getElementById('editRoll');
    const editFather = document.getElementById('editFather');
    const editStatus = document.getElementById('editStatus');
    const editPhotoPreview = document.getElementById('editPhotoPreview');

    editButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        const id = btn.getAttribute('data-id');
        const name = btn.getAttribute('data-name');
        const email = btn.getAttribute('data-email');
        const className = btn.getAttribute('data-class');
        const section = btn.getAttribute('data-section');
        const roll = btn.getAttribute('data-roll');
        const father = btn.getAttribute('data-father');
        const status = btn.getAttribute('data-status');
        const photo = btn.getAttribute('data-photo');

        // Dynamically assign form action route
        editForm.action = `/admin/students/edit/${id}`;
        
        // Populate inputs
        editName.value = name;
        editEmail.value = email;
        editClass.value = className;
        editSection.value = section;
        editRoll.value = roll;
        editFather.value = father;
        editStatus.value = status;
        editPhotoPreview.src = photo || '/uploads/default-avatar.png';
      });
    });

    // Client-side real-time preview for Add student modal
    document.getElementById('addPhoto').addEventListener('change', function(event) {
      const file = event.target.files[0];
      if (file) {
        if (file.size > 2 * 1024 * 1024) {
          alert('File size exceeds 2MB limit! Please select a smaller photo.');
          event.target.value = '';
          return;
        }
        const reader = new FileReader();
        reader.onload = function(e) {
          document.getElementById('addPhotoPreview').src = e.target.result;
        };
        reader.readAsDataURL(file);
      }
    });

    // Client-side real-time preview for Edit student modal
    document.getElementById('editPhoto').addEventListener('change', function(event) {
      const file = event.target.files[0];
      if (file) {
        if (file.size > 2 * 1024 * 1024) {
          alert('File size exceeds 2MB limit! Please select a smaller photo.');
          event.target.value = '';
          return;
        }
        const reader = new FileReader();
        reader.onload = function(e) {
          document.getElementById('editPhotoPreview').src = e.target.result;
        };
        reader.readAsDataURL(file);
      }
    });
  });
</script>

<%- include('../partials/footer') %>
