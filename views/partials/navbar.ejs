<header class="top-bar-tvm">
  <div class="d-flex align-items-center gap-3">
    <button class="btn btn-tvm-secondary d-lg-none" id="sidebar-toggle" aria-label="Toggle Navigation Sidebar">
      <i class="fa-solid fa-bars"></i>
    </button>
    <div>
      <h4 class="mb-0 text-white font-weight-bold" style="font-size: 1.25rem;">TVM Public School ERP</h4>
      <p class="text-muted mb-0 d-none d-sm-block" style="font-size: 0.85rem;">Patna Branch, Bihar</p>
    </div>
  </div>
  
  <div class="d-flex align-items-center gap-3">
    <div class="text-end d-none d-md-block">
      <h6 class="mb-0 text-white font-weight-bold" style="font-size: 0.95rem;"><%= user.name %></h6>
      <span class="badge text-uppercase font-weight-bold" style="font-size: 0.75rem; background: var(--accent-glow); color: #090D1A;"><%= user.role %></span>
    </div>
    
    <div class="dropdown">
      <button class="btn p-0 border-0 dropdown-toggle no-caret" type="button" data-bs-toggle="dropdown" aria-expanded="false">
        <img src="<%= user.photo || '/uploads/default-avatar.png' %>" alt="User profile photo" class="rounded-circle border border-secondary" style="width: 44px; height: 44px; object-fit: cover;">
      </button>
      <ul class="dropdown-menu dropdown-menu-end border-0 shadow-lg glass-card p-2" style="background: var(--bg-slate); width: 220px;">
        <li class="px-3 py-2 border-bottom border-secondary mb-2 text-center d-md-none">
          <h6 class="mb-0 text-white font-weight-bold"><%= user.name %></h6>
          <span class="badge text-uppercase mt-1" style="background: var(--accent-glow); color: #090D1A;"><%= user.role %></span>
        </li>
        <% if (user.role === 'student') { %>
          <li>
            <a class="dropdown-item text-white rounded-3 py-2" href="/student/profile">
              <i class="fa-regular fa-user me-2 text-info"></i> View Profile
            </a>
          </li>
        <% } else if (user.role === 'teacher') { %>
          <li>
            <a class="dropdown-item text-white rounded-3 py-2" href="/teacher/profile">
              <i class="fa-regular fa-user me-2 text-info"></i> View Profile
            </a>
          </li>
        <% } else if (user.role === 'admin') { %>
          <li>
            <a class="dropdown-item text-white rounded-3 py-2" href="/admin/profile">
              <i class="fa-regular fa-user me-2 text-info"></i> View Profile
            </a>
          </li>
        <% } %>
        <li>
          <a class="dropdown-item text-danger rounded-3 py-2" href="/logout">
            <i class="fa-solid fa-arrow-right-from-bracket me-2"></i> Log Out
          </a>
        </li>
      </ul>
    </div>
  </div>
</header>
