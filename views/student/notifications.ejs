<%- include('../partials/header') %>

<div class="dashboard-layout">
  
  <!-- Sidebar -->
  <%- include('../partials/sidebar') %>
  
  <!-- Main Contents -->
  <main class="main-content-tvm">
    
    <!-- Top Nav Navbar -->
    <%- include('../partials/navbar') %>
    
    <!-- Session Messages -->
    <%- include('../partials/messages') %>
    
    <div class="container-fluid p-0">
      
      <!-- Welcome Banner -->
      <div class="row mb-4">
        <div class="col-12">
          <h2 class="text-white font-weight-bold mb-1">Alerts & System Notifications</h2>
          <p class="text-secondary mb-0">Check the notice board for emergency announcements, holidays timetables, or general events news.</p>
        </div>
      </div>

      <div class="row g-4">
        <!-- Announcements Feed -->
        <div class="col-xl-8">
          <div class="glass-card shadow-lg h-100">
            <h5 class="text-white font-weight-bold mb-4">
              <i class="fa-solid fa-bullhorn text-warning me-2"></i>Active Bulletins Board
            </h5>
            
            <% if (notices.length === 0) { %>
              <div class="text-center py-5 text-muted">
                <i class="fa-regular fa-folder-open display-4 mb-3 d-block text-secondary"></i>
                No active announcements published yet. Check back later.
              </div>
            <% } else { %>
              <div class="d-flex flex-column gap-3">
                <% notices.forEach(notice => { %>
                  <div class="p-3 rounded-3 border border-secondary" style="background: rgba(255, 255, 255, 0.015);">
                    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-2">
                      <div>
                        <h6 class="text-white font-weight-bold mb-1"><%= notice.title %></h6>
                        <small class="text-secondary">
                          <i class="fa-regular fa-user me-1"></i> Posted by <%= notice.createdBy %> 
                          &nbsp;&bull;&nbsp; 
                          <i class="fa-regular fa-calendar-days me-1"></i> <%= new Date(notice.createdAt).toLocaleString('en-IN') %>
                        </small>
                      </div>
                      
                      <% if (notice.targetRole === 'all') { %>
                        <span class="status-badge status-present">Public Bulletin</span>
                      <% } else { %>
                        <span class="status-badge status-active">Student Directives</span>
                      <% } %>
                    </div>
                    
                    <p class="text-secondary mb-0 fs-7" style="white-space: pre-wrap; line-height: 1.5;"><%= notice.content %></p>
                  </div>
                <% }) %>
              </div>
            <% } %>
          </div>
        </div>

        <!-- Right Quick Tips -->
        <div class="col-xl-4">
          <div class="glass-card shadow-lg h-100 d-flex flex-column justify-content-between">
            <div>
              <h5 class="text-white font-weight-bold mb-3"><i class="fa-solid fa-bell text-info me-2"></i>Notice Board Guidance</h5>
              <p class="text-secondary mb-3 fs-7" style="line-height: 1.5;">
                Announcements published inside this board are issued by TVM Admin or your class teachers. Keep the following in mind:
              </p>
              
              <ul class="list-unstyled d-flex flex-column gap-3 mb-0 fs-7 text-secondary">
                <li class="d-flex gap-3 align-items-start">
                  <i class="fa-solid fa-circle-info text-info mt-1"></i>
                  <div>
                    <strong class="text-white">Emergency Alerts:</strong> Announcements concerning class scheduling shifts or weather holidays are published here instantly.
                  </div>
                </li>
                <li class="d-flex gap-3 align-items-start">
                  <i class="fa-solid fa-circle-info text-info mt-1"></i>
                  <div>
                    <strong class="text-white">Events Board:</strong> Monitor notices for annual sports programs, parents teachers conferences (PTA), and science exhibitions.
                  </div>
                </li>
              </ul>
            </div>
            
            <div class="p-3 rounded border border-info mt-4" style="background: rgba(0, 242, 254, 0.03);">
              <h6 class="text-info font-weight-bold mb-2 fs-7"><i class="fa-solid fa-shield-halved me-2"></i>Official Records</h6>
              <p class="text-secondary mb-0 fs-8" style="line-height: 1.4;">
                This database compiles verified ERP records only. Disregard external notices unless posted directly onto this official TVM screen.
              </p>
            </div>
          </div>
        </div>
      </div>

    </div>
  </main>
</div>

<%- include('../partials/footer') %>
