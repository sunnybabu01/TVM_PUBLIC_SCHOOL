<%- include('../partials/header') %>

<div class="dashboard-layout">
  
  <!-- Sidebar -->
  <%- include('../partials/sidebar') %>
  
  <!-- Main Contents -->
  <main class="main-content-tvm">
    
    <!-- Top Nav Navbar -->
    <%- include('../partials/navbar') %>
    
    <!-- Session Messages -->
    <%- include('../partials/messages') %>
    
    <div class="container-fluid p-0">
      
      <!-- Welcome Banner -->
      <div class="row mb-4">
        <div class="col-12 d-flex justify-content-between align-items-center flex-wrap gap-3">
          <div>
            <h2 class="text-white font-weight-bold mb-1">Homework Board & Study Materials</h2>
            <p class="text-secondary mb-0">Assign lessons, upload syllabuses, post class homework, and distribute reading lists.</p>
          </div>
          <button class="btn btn-tvm-primary" data-bs-toggle="modal" data-bs-target="#assignHomeworkModal">
            <i class="fa-solid fa-plus me-2"></i>Assign New Homework
          </button>
        </div>
      </div>

      <!-- Homework assignments Feed -->
      <div class="row g-4">
        <div class="col-xl-8">
          <div class="glass-card shadow-lg h-100">
            <h5 class="text-white font-weight-bold mb-4">
              <i class="fa-solid fa-book text-info me-2"></i>My Posted Homework Tasks
            </h5>
            
            <% if (homeworkPosts.length === 0) { %>
              <div class="text-center py-5 text-muted">
                <i class="fa-regular fa-folder-open display-4 mb-3 d-block text-secondary"></i>
                No homework tasks posted yet. Assign your first task using the button.
              </div>
            <% } else { %>
              <div class="d-flex flex-column gap-3">
                <% homeworkPosts.forEach(post => { %>
                  <div class="p-3 rounded-3 border border-secondary" style="background: rgba(255, 255, 255, 0.015);">
                    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-2">
                      <div>
                        <h6 class="text-white font-weight-bold mb-1"><%= post.title %></h6>
                        <small class="text-secondary">
                          <i class="fa-regular fa-calendar-days me-1"></i> Posted on <%= new Date(post.createdAt).toLocaleString('en-IN') %>
                        </small>
                      </div>
                      
                      <!-- Extract and display class target from content -->
                      <% const classMatch = post.content.match(/Target Class:\s*(\w+)/i) %>
                      <span class="status-badge status-present">
                        Class <%= classMatch ? classMatch[1] : 'All' %>
                      </span>
                    </div>
                    
                    <p class="text-secondary mb-0 fs-7" style="white-space: pre-wrap; line-height: 1.5;"><%= post.content %></p>
                  </div>
                <% }) %>
              </div>
            <% } %>
          </div>
        </div>

        <!-- Department/Subject Info Card -->
        <div class="col-xl-4">
          <div class="glass-card shadow-lg h-100 d-flex flex-column justify-content-between">
            <div>
              <h5 class="text-white font-weight-bold mb-3"><i class="fa-solid fa-graduation-cap text-warning me-2"></i>Syllabus & Assignments Guidelines</h5>
              <p class="text-secondary mb-3 fs-7" style="line-height: 1.5;">
                When assigning homework through this dashboard:
              </p>
              
              <ul class="list-unstyled d-flex flex-column gap-3 mb-0 fs-7 text-secondary">
                <li class="d-flex gap-3 align-items-start">
                  <i class="fa-solid fa-circle-check text-info mt-1"></i>
                  <div>
                    <strong class="text-white">Instant Sync:</strong> Homework records are immediately indexed on matching Student homework boards.
                  </div>
                </li>
                <li class="d-flex gap-3 align-items-start">
                  <i class="fa-solid fa-circle-check text-info mt-1"></i>
                  <div>
                    <strong class="text-white">Clear Directions:</strong> Provide details such as submission timelines, page numbers, and required study references.
                  </div>
                </li>
                <li class="d-flex gap-3 align-items-start">
                  <i class="fa-solid fa-circle-check text-info mt-1"></i>
                  <div>
                    <strong class="text-white">Subject Gated:</strong> Homework is tagged automatically with your specialized subject (<strong class="text-info"><%= subject %></strong>).
                  </div>
                </li>
              </ul>
            </div>
            
            <div class="p-3 rounded border border-info mt-4" style="background: rgba(0, 242, 254, 0.03);">
              <h6 class="text-info font-weight-bold mb-2 fs-7"><i class="fa-solid fa-circle-info me-2"></i>Offline Access Ready</h6>
              <p class="text-secondary mb-0 fs-8" style="line-height: 1.4;">
                Students can access and copy homework descriptions from any terminal or printable views. Keep messages simple and clear.
              </p>
            </div>
          </div>
        </div>
      </div>

    </div>
  </main>
</div>

<!-- Assign Homework Modal -->
<div class="modal fade" id="assignHomeworkModal" tabindex="-1" aria-labelledby="assignHomeworkModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content bg-dark border border-secondary text-white">
      <div class="modal-header border-secondary">
        <h5 class="modal-title font-weight-bold" id="assignHomeworkModalLabel">Assign Classroom Homework</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form action="/teacher/homework" method="POST">
        <div class="modal-body">
          <div class="mb-3">
            <label class="glass-label">Homework Title</label>
            <input type="text" name="title" class="form-control glass-input" required placeholder="e.g. Newton's Laws Exercise Problems">
          </div>
          <div class="mb-3">
            <label class="glass-label">Target Class</label>
            <select name="targetClass" class="form-select glass-input" required>
              <option value="1">Class 1</option>
              <option value="2">Class 2</option>
              <option value="3">Class 3</option>
              <option value="4">Class 4</option>
              <option value="5">Class 5</option>
              <option value="6">Class 6</option>
              <option value="7">Class 7</option>
              <option value="8">Class 8</option>
              <option value="9" selected>Class 9</option>
              <option value="10">Class 10</option>
              <option value="11">Class 11</option>
              <option value="12">Class 12</option>
            </select>
          </div>
          <div class="mb-3">
            <label class="glass-label">Detailed Assignment Instructions</label>
            <textarea name="content" class="form-control glass-input" rows="6" required placeholder="Write question details, due dates, references, and descriptions..."></textarea>
          </div>
        </div>
        <div class="modal-footer border-secondary">
          <button type="button" class="btn btn-tvm-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-tvm-primary">Upload & Publish</button>
        </div>
      </form>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
