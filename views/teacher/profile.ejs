<%- include('../partials/header') %>

<div class="dashboard-layout">
  
  <!-- Sidebar -->
  <%- include('../partials/sidebar') %>
  
  <!-- Main Contents -->
  <main class="main-content-tvm">
    
    <!-- Top Nav Navbar -->
    <%- include('../partials/navbar') %>
    
    <!-- Session Messages -->
    <%- include('../partials/messages') %>
    
    <div class="container-fluid p-0">
      
      <!-- Welcome Banner -->
      <div class="row mb-4">
        <div class="col-12">
          <h2 class="text-white font-weight-bold mb-1">Faculty Profile Center</h2>
          <p class="text-secondary mb-0">Manage your educator credentials, contact details, and account security.</p>
        </div>
      </div>

      <div class="row g-4">
        <!-- Avatar card -->
        <div class="col-lg-4">
          <div class="glass-card shadow-lg text-center h-100 d-flex flex-column justify-content-center py-5">
            <form action="/teacher/profile/update" method="POST" enctype="multipart/form-data" id="avatar-form">
              <div class="mb-4 position-relative d-inline-block mx-auto">
                <img src="<%= teacher.photo || '/uploads/default-avatar.png' %>" alt="Teacher Photo" id="profile-avatar-preview" class="rounded-circle border border-info img-thumbnail" style="width: 150px; height: 150px; object-fit: cover; background: transparent;">
                <label for="photo-upload" class="position-absolute bottom-0 end-0 bg-info text-dark rounded-circle border border-dark p-2 cursor-pointer shadow-lg hover-scale" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; cursor: pointer;">
                  <i class="fa-solid fa-camera"></i>
                </label>
                <input type="file" name="photo" id="photo-upload" accept="image/png, image/jpeg, image/jpg" class="d-none">
              </div>
              <h4 class="text-white font-weight-bold mb-1"><%= teacher.name %></h4>
              <p class="text-info font-weight-bold mb-3">ID: <%= teacher.teacherId %></p>
              <div class="mb-4">
                <span class="status-badge status-present">
                  <i class="fa-solid fa-graduation-cap me-1"></i><%= teacher.subject.toUpperCase() %> FACULTY
                </span>
              </div>
              <p class="text-muted fs-8 px-3">Click the camera icon to upload a new profile photo. Max file size: 2MB.</p>
              <button type="submit" class="btn btn-tvm-primary btn-sm px-4 mt-2 d-none" id="save-avatar-btn">
                <i class="fa-solid fa-cloud-arrow-up me-1"></i> Save Photo
              </button>
            </form>
          </div>
        </div>

        <!-- Details card -->
        <div class="col-lg-8">
          <div class="glass-card shadow-lg">
            <h5 class="text-white font-weight-bold mb-4 border-bottom border-secondary pb-3">
              <i class="fa-solid fa-user-gear text-info me-2"></i>Profile & Security Settings
            </h5>
            
            <form action="/teacher/profile/update" method="POST" class="needs-validation">
              <div class="row g-4">
                <!-- Name field -->
                <div class="col-md-6">
                  <label for="name" class="form-label text-secondary font-weight-bold fs-8">FULL EDUCATOR NAME</label>
                  <div class="input-group">
                    <span class="input-group-text bg-dark border-secondary text-secondary"><i class="fa-solid fa-user-tie"></i></span>
                    <input type="text" name="name" id="name" class="form-control bg-dark border-secondary text-white font-weight-bold" value="<%= teacher.name %>" required>
                  </div>
                </div>

                <!-- Subject (Locked) field -->
                <div class="col-md-6">
                  <label class="form-label text-secondary font-weight-bold fs-8">ASSIGNED SUBJECT DEPT (READ-ONLY)</label>
                  <div class="input-group">
                    <span class="input-group-text bg-dark border-secondary text-secondary"><i class="fa-solid fa-book"></i></span>
                    <input type="text" class="form-control bg-dark border-secondary text-secondary font-weight-bold" value="<%= teacher.subject %>" readonly>
                  </div>
                </div>

                <!-- Email field -->
                <div class="col-md-6">
                  <label for="email" class="form-label text-secondary font-weight-bold fs-8">EMAIL ADDRESS</label>
                  <div class="input-group">
                    <span class="input-group-text bg-dark border-secondary text-secondary"><i class="fa-regular fa-envelope"></i></span>
                    <input type="email" name="email" id="email" class="form-control bg-dark border-secondary text-white" value="<%= teacher.email %>" required>
                  </div>
                </div>

                <!-- Phone field -->
                <div class="col-md-6">
                  <label for="phone" class="form-label text-secondary font-weight-bold fs-8">CONTACT PHONE NUMBER</label>
                  <div class="input-group">
                    <span class="input-group-text bg-dark border-secondary text-secondary"><i class="fa-solid fa-phone"></i></span>
                    <input type="tel" name="phone" id="phone" class="form-control bg-dark border-secondary text-white" value="<%= teacher.phone || '' %>">
                  </div>
                </div>
                
                <!-- Separator -->
                <div class="col-12 mt-4 mb-2">
                  <h6 class="text-white font-weight-bold fs-7"><i class="fa-solid fa-key me-2 text-warning"></i>Change Password</h6>
                  <small class="text-muted d-block mb-3">Leave blank if you do not wish to update your current account password.</small>
                </div>

                <!-- Passwords -->
                <div class="col-md-6">
                  <label for="password" class="form-label text-secondary font-weight-bold fs-8">NEW PASSWORD</label>
                  <div class="input-group">
                    <span class="input-group-text bg-dark border-secondary text-secondary"><i class="fa-solid fa-lock"></i></span>
                    <input type="password" name="password" id="password" class="form-control bg-dark border-secondary text-white" placeholder="Enter new password">
                  </div>
                </div>

                <div class="col-md-6">
                  <label for="confirmPassword" class="form-label text-secondary font-weight-bold fs-8">CONFIRM NEW PASSWORD</label>
                  <div class="input-group">
                    <span class="input-group-text bg-dark border-secondary text-secondary"><i class="fa-solid fa-lock-open"></i></span>
                    <input type="password" name="confirmPassword" id="confirmPassword" class="form-control bg-dark border-secondary text-white" placeholder="Repeat new password">
                  </div>
                </div>

                <!-- Save Button -->
                <div class="col-12 text-end mt-4">
                  <button type="submit" class="btn btn-tvm-primary px-4 py-2 font-weight-bold">
                    <i class="fa-solid fa-floppy-disk me-2"></i>Save Profile
                  </button>
                </div>
              </div>
            </form>
          </div>
        </div>
      </div>

    </div>
  </main>
</div>

<!-- Client-side real-time preview script -->
<script>
  document.getElementById('photo-upload').addEventListener('change', function(event) {
    const file = event.target.files[0];
    if (file) {
      // Validate file size (2MB)
      if (file.size > 2 * 1024 * 1024) {
        alert('File size exceeds 2MB limit! Please select a smaller photo.');
        event.target.value = '';
        return;
      }
      
      // Update image preview
      const reader = new FileReader();
      reader.onload = function(e) {
        document.getElementById('profile-avatar-preview').src = e.target.result;
        // Show the save button
        document.getElementById('save-avatar-btn').classList.remove('d-none');
      };
      reader.readAsDataURL(file);
    }
  });
</script>

<%- include('../partials/footer') %>
